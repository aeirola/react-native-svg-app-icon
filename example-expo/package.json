{
  "name": "svg-app-icon-expo-example",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "postinstall": "install-local",
    "prepare": "expo prebuild && npm run clean-icons && react-native-svg-app-icon",
    "clean-icons": "npx --yes rimraf \"android/app/src/main/res/mipmap-*\" \"ios/**/AppIcon.appiconset\"",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "icon": "npx install-local && react-native-svg-app-icon"
  },
  "dependencies": {
    "expo": "~55.0.7",
    "expo-dev-client": "~55.0.17",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "private": true,
  "devDependencies": {
    "install-local": "^4.1.0"
  },
  "localDependencies": {
    "react-native-svg-app-icon": ".."
  }
}